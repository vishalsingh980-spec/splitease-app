{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/client/static/$1" },
    { "src": "/(.*)\\.(.+)", "dest": "/client/$1.$2" },
    { "src": "/(.*)", "dest": "/client/index.html" }
  ]
}
